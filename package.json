{
  "name": "@knostic/openclaw-shield",
  "version": "0.2.0",
  "description": "Security guardrail plugin for OpenClaw — blocks destructive commands, redacts secrets and PII",
  "type": "module",
  "openclaw": {
    "extensions": ["./src/index.ts"]
  },
  "files": [
    "src/",
    "docs/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "security",
    "guardrails",
    "pii",
    "secrets",
    "redaction"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/knostic/openclaw-shield"
  },
  "license": "MIT",
  "author": "Knostic",
  "peerDependencies": {
    "openclaw": "*"
  },
  "scripts": {
    "test": "node --import tsx --test src/command-policy.test.ts src/foundation-models-scan.test.ts src/prompt-extract.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
